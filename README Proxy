<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PROXY LAUNCHER 2026</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Courier New', monospace;
      background: #000;
      color: #00ff41;
      overflow: hidden;
      height: 100vh;
    }

    #binary-bg {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      z-index: -1;
      opacity: 0.18;
      pointer-events: none;
    }

    .container {
      position: relative;
      z-index: 1;
      text-align: center;
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    h1 {
      font-size: 58px;
      margin-bottom: 40px;
      text-shadow: 0 0 25px #00ff41;
    }

    button {
      padding: 15px 40px;
      margin: 12px;
      font-size: 21px;
      font-weight: bold;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.3s;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .play-btn {
      font-size: 65px;
      padding: 50px 110px;
      background: #001a00;
      color: #00ff41;
      border: 4px solid #00ff41;
      box-shadow: 0 0 50px #00ff41,
                  0 0 90px #00ff41;
    }
    .play-btn:hover {
      background: #003300;
      box-shadow: 0 0 70px #00ff41,
                  0 0 120px #00ff41;
      transform: scale(1.1);
    }

    .proxy-btn {
      background: #001a00;
      color: #00ff41;
      border: 2px solid #00ff41;
      width: 340px;
      box-shadow: 0 0 30px #00ff41;
    }
    .proxy-btn:hover {
      background: #003300;
      box-shadow: 0 0 50px #00ff41;
      transform: translateY(-6px);
    }

    .back-btn {
      background: #001a00;
      color: #00ff41;
      border: 2px solid #00ff41;
      padding: 14px 35px;
      margin-top: 25px;
      box-shadow: 0 0 25px #00ff41;
    }
    .back-btn:hover {
      background: #003300;
      box-shadow: 0 0 45px #00ff41;
    }

    iframe {
      width: 96%;
      max-width: 1450px;
      height: 78vh;
      border: 4px solid #00ff41;
      border-radius: 15px;
      box-shadow: 0 0 50px #00ff41;
      background: #000;
    }

    .hidden { display: none; }
  </style>
</head>
<body>

  <canvas id="binary-bg"></canvas>

  <!-- Pantalla 1 -->
  <div id="screen1" class="container">
    <h1>PROXY LAUNCHER 2026</h1>
    <button class="play-btn" onclick="showProxySelection()">PLAY</button>
  </div>

  <!-- Pantalla 2: Proxies -->
  <div id="screen2" class="container hidden">
    <h2 style="margin-bottom: 40px; text-shadow: 0 0 20px #00ff41;">ELIGE UN PROXY</h2>
    
    <button class="proxy-btn" onclick="loadProxy(1)">1. CroxyProxy</button><br>
    <button class="proxy-btn" onclick="loadProxy(2)">2. ProxySite</button><br>
    <button class="proxy-btn" onclick="loadProxy(3)">3. Hide.me</button><br>
    <button class="proxy-btn" onclick="loadProxy(4)">4. 4everProxy</button><br>
    <button class="proxy-btn" onclick="loadProxy(5)">5. BlockAway</button><br>
    <button class="proxy-btn" onclick="loadProxy(6)">6. SSLUnblocker</button>

    <br><br>
    <button class="back-btn" onclick="backToHome()">Volver al Inicio</button>
  </div>

  <!-- Pantalla 3: Iframe -->
  <div id="screen3" class="container hidden">
    <h2 id="proxy-title" style="margin-bottom: 20px; text-shadow: 0 0 20px #00ff41;">Cargando Proxy...</h2>
    <iframe id="proxyFrame" src="" frameborder="0"></iframe>
    <br>
    <button class="back-btn" onclick="backToProxies()">ATRAS</button>
  </div>

  <script>
    // Fondo Matrix
    const canvas = document.getElementById("binary-bg");
    const ctx = canvas.getContext("2d");
    canvas.height = window.innerHeight;
    canvas.width = window.innerWidth;

    const binary = "01";
    const fontSize = 14;
    const columns = canvas.width / fontSize;
    const drops = Array(Math.floor(columns)).fill(1);

    function draw() {
      ctx.fillStyle = "rgba(0, 0, 0, 0.07)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = "#00ff41";
      ctx.font = fontSize + "px monospace";

      for (let i = 0; i < drops.length; i++) {
        const text = binary[Math.floor(Math.random() * binary.length)];
        ctx.fillText(text, i * fontSize, drops[i] * fontSize);

        if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
        drops[i]++;
      }
    }
    setInterval(draw, 35);

    // Proxies actualizados 2026
    const proxies = {
      1: { name: "CroxyProxy", url: "https://www.croxyproxy.com/?url=" },
      2: { name: "ProxySite", url: "https://www.proxysite.com/?u=" },
      3: { name: "Hide.me", url: "https://hide.me/en/proxy?url=" },
      4: { name: "4everProxy", url: "https://www.4everproxy.com/?url=" },
      5: { name: "BlockAway", url: "https://www.blockaway.net/?url=" },
      6: { name: "SSLUnblocker", url: "https://www.sslunblocker.com/?url=" }
    };

    function showProxySelection() {
      document.getElementById("screen1").classList.add("hidden");
      document.getElementById("screen2").classList.remove("hidden");
    }

    function loadProxy(id) {
      const proxy = proxies[id];
      document.getElementById("proxy-title").textContent = proxy.name;

      // Abre directamente Google Sites (puedes cambiar la URL por defecto)
      const target = "https://sites.google.com/";
      const fullUrl = proxy.url + encodeURIComponent(target);
      
      document.getElementById("proxyFrame").src = fullUrl;
      
      document.getElementById("screen2").classList.add("hidden");
      document.getElementById("screen3").classList.remove("hidden");
    }

    function backToProxies() {
      document.getElementById("proxyFrame").src = "";
      document.getElementById("screen3").classList.add("hidden");
      document.getElementById("screen2").classList.remove("hidden");
    }

    function backToHome() {
      document.getElementById("screen2").classList.add("hidden");
      document.getElementById("screen1").classList.remove("hidden");
    }

    window.addEventListener("resize", () => {
      canvas.height = window.innerHeight;
      canvas.width = window.innerWidth;
    });
  </script>
</body>
</html>
